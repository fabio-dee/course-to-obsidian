# Copy to .env and fill in your values. .env is gitignored.
#
# The Obsidian vault builder can classify lessons using either:
#   (a) Anthropic Haiku (cloud) — via Claude CLI/Max subscription OR ANTHROPIC_API_KEY
#   (b) A local OpenAI-compatible LLM server (llama.cpp, vLLM, LM Studio, Ollama in openai mode, etc.)
#
# Use (b) if you want to avoid API costs or rate limits and have a capable local model
# (we've tested Qwen3-35B-A3B — decent for ideation, weaker at vocabulary discipline).

# ---- Local LLM (OpenAI-compatible) ----
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_LLM_MODEL=your-model-name
LOCAL_LLM_API_KEY=not-needed           # many local servers ignore this, but the OpenAI SDK requires some value
# Disable thinking blocks on Qwen3-family models (saves 60-90% completion tokens on classification).
LOCAL_LLM_DISABLE_THINKING=1

# ---- Anthropic (cloud) ----
# Only needed if you run the vault builder with --backend api.
# Leave unset to use the Claude CLI / Max subscription via --backend sdk (default).
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Canonicalization pass (--canonicalize) ----
# One global call that dedups tag/concept names across the whole vault.
# Use an Opus-class model — the reasoning quality matters more than speed here.
CANON_BACKEND=sdk                      # sdk|api|local  (sdk = Claude CLI / Max subscription, free)
CANON_MODEL=claude-opus-4-7            # any Anthropic model id, or a local model if CANON_BACKEND=local
